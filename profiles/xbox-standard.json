{
  "id": "xbox-standard",
  "name": "Xbox Standard",
  "mode": "xInput",
  "opacity": 0.7,
  "scale": 1.0,
  "controls": [
    {
      "id": "a-button",
      "type": "button",
      "label": "A",
      "position": { "x": 0.85, "y": 0.60 },
      "size": { "width": 56, "height": 56 },
      "style": { "fill": "#107C10", "stroke": "#0E6B0E" },
      "binding": {
        "xInput": "A",
        "keyboard": "Space"
      }
    },
    {
      "id": "b-button",
      "type": "button",
      "label": "B",
      "position": { "x": 0.90, "y": 0.52 },
      "size": { "width": 56, "height": 56 },
      "style": { "fill": "#E81123", "stroke": "#C50F1F" },
      "binding": {
        "xInput": "B",
        "keyboard": "Escape"
      }
    },
    {
      "id": "x-button",
      "type": "button",
      "label": "X",
      "position": { "x": 0.80, "y": 0.52 },
      "size": { "width": 56, "height": 56 },
      "style": { "fill": "#0078D7", "stroke": "#005A9E" },
      "binding": {
        "xInput": "X",
        "keyboard": "E"
      }
    },
    {
      "id": "y-button",
      "type": "button",
      "label": "Y",
      "position": { "x": 0.85, "y": 0.44 },
      "size": { "width": 56, "height": 56 },
      "style": { "fill": "#FDB813", "stroke": "#D69E10" },
      "binding": {
        "xInput": "Y",
        "keyboard": "R"
      }
    },
    {
      "id": "left-bumper",
      "type": "button",
      "label": "LB",
      "position": { "x": 0.10, "y": 0.15 },
      "size": { "width": 80, "height": 40 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "LeftShoulder",
        "keyboard": "Q"
      }
    },
    {
      "id": "right-bumper",
      "type": "button",
      "label": "RB",
      "position": { "x": 0.83, "y": 0.15 },
      "size": { "width": 80, "height": 40 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "RightShoulder",
        "keyboard": "P"
      }
    },
    {
      "id": "start",
      "type": "button",
      "label": "Start",
      "position": { "x": 0.55, "y": 0.45 },
      "size": { "width": 48, "height": 32 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "Start",
        "keyboard": "Enter"
      }
    },
    {
      "id": "back",
      "type": "button",
      "label": "Back",
      "position": { "x": 0.40, "y": 0.45 },
      "size": { "width": 48, "height": 32 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "Back",
        "keyboard": "Backspace"
      }
    },
    {
      "id": "guide",
      "type": "button",
      "label": "Guide",
      "position": { "x": 0.475, "y": 0.38 },
      "size": { "width": 40, "height": 40 },
      "style": { "fill": "#107C10", "stroke": "#0E6B0E" },
      "binding": {
        "xInput": "Guide",
        "keyboard": "Home"
      }
    },
    {
      "id": "left-stick",
      "type": "stick",
      "label": "LS",
      "position": { "x": 0.15, "y": 0.45 },
      "size": { "width": 140, "height": 140, "radius": 70 },
      "deadZone": 0.15,
      "binding": {
        "xInput": "LeftThumb",
        "keyboardDirectional": { "up": "W", "down": "S", "left": "A", "right": "D" }
      }
    },
    {
      "id": "right-stick",
      "type": "stick",
      "label": "RS",
      "position": { "x": 0.72, "y": 0.65 },
      "size": { "width": 120, "height": 120, "radius": 60 },
      "deadZone": 0.15,
      "binding": {
        "xInput": "RightThumb",
        "keyboardDirectional": { "up": "Up", "down": "Down", "left": "Left", "right": "Right" }
      }
    },
    {
      "id": "left-trigger",
      "type": "trigger",
      "label": "LT",
      "position": { "x": 0.08, "y": 0.05 },
      "size": { "width": 50, "height": 100 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "LeftTrigger",
        "keyboard": "Tab"
      }
    },
    {
      "id": "right-trigger",
      "type": "trigger",
      "label": "RT",
      "position": { "x": 0.88, "y": 0.05 },
      "size": { "width": 50, "height": 100 },
      "style": { "fill": "#3A3A3A", "stroke": "#555555" },
      "binding": {
        "xInput": "RightTrigger",
        "keyboard": "LeftMouseButton"
      }
    },
    {
      "id": "dpad",
      "type": "dPad",
      "label": "D-Pad",
      "position": { "x": 0.22, "y": 0.68 },
      "size": { "width": 120, "height": 120 },
      "binding": {
        "xInput": "DPad",
        "keyboardDirectional": { "up": "Up", "down": "Down", "left": "Left", "right": "Right" }
      }
    }
  ]
}
