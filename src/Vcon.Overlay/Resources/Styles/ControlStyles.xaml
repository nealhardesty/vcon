<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Xbox brand colors -->
    <Color x:Key="XboxGreenColor">#107C10</Color>
    <Color x:Key="ButtonAColor">#107C10</Color>
    <Color x:Key="ButtonBColor">#E81123</Color>
    <Color x:Key="ButtonXColor">#0078D7</Color>
    <Color x:Key="ButtonYColor">#FDB813</Color>

    <!-- Solid brushes for button fills -->
    <SolidColorBrush x:Key="XboxGreenBrush" Color="{StaticResource XboxGreenColor}" />
    <SolidColorBrush x:Key="ButtonABrush" Color="{StaticResource ButtonAColor}" />
    <SolidColorBrush x:Key="ButtonBBrush" Color="{StaticResource ButtonBColor}" />
    <SolidColorBrush x:Key="ButtonXBrush" Color="{StaticResource ButtonXColor}" />
    <SolidColorBrush x:Key="ButtonYBrush" Color="{StaticResource ButtonYColor}" />

    <!-- Common control brushes (semi-transparent) -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#99222222" />
    <SolidColorBrush x:Key="ControlStrokeBrush" Color="#CC888888" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#CC444444" />
    <SolidColorBrush x:Key="ControlTextBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="StickZoneBrush" Color="#66333333" />
    <SolidColorBrush x:Key="StickThumbBrush" Color="#CC666666" />
    <SolidColorBrush x:Key="DPadBackgroundBrush" Color="#99333333" />
    <SolidColorBrush x:Key="DPadHighlightBrush" Color="#CC555555" />

    <!-- Base style for virtual controls -->
    <Style x:Key="VirtualControlBase" TargetType="UserControl">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
    </Style>

</ResourceDictionary>
