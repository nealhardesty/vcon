<UserControl x:Class="Vcon.Overlay.Controls.VirtualButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Style="{StaticResource VirtualControlBase}">
    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="PressTransform" ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>
        <Ellipse x:Name="BackgroundEllipse"
                 Fill="{StaticResource ControlBackgroundBrush}"
                 Stroke="{StaticResource ControlStrokeBrush}"
                 StrokeThickness="2" />
        <TextBlock x:Name="LabelText"
                   Text="A"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource ControlTextBrush}"
                   FontWeight="Bold"
                   IsHitTestVisible="False" />
    </Grid>
</UserControl>
